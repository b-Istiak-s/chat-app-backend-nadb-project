APP_NAME="Chat App"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ─────────────────────────────────────────────────────────────────────
# Robi BDApps gateway (Robi Axiata, Bangladesh)
# ─────────────────────────────────────────────────────────────────────
BDAPPS_BASE_URL=https://developer.bdapps.com
BDAPPS_APPLICATION_ID=APP_xxxxxx
BDAPPS_PASSWORD=
BDAPPS_APPLICATION_HASH="Chat App"
BDAPPS_NOTIFY_SECRET=change-me-locally
BDAPPS_COUNTRY_CODE=880
BDAPPS_TIMEOUT=30
BDAPPS_VERIFY_SSL=true
BDAPPS_SUCCESS_STATUS_CODE=S1000

# /sms/send options (Mobile-Terminated SMS)
BDAPPS_SMS_SEND_ENDPOINT=/sms/send
BDAPPS_SMS_SOURCE_ADDRESS=
BDAPPS_SMS_DELIVERY_STATUS=0
BDAPPS_SMS_ENCODING=0

# Send a courtesy SMS when an already-trusted user (subscribed or
# pending) skips OTP and signs in directly. Defaults off — flip to
# 1 in production once the /sms/send path is wired in the gateway.
BDAPPS_LOGIN_SMS_NOTIFY_ENABLED=false

# Fire a milestone SMS via /sms/send every time a user completes
# their 5th, 10th, 15th… AI chat. Defaults off — enable in prod.
CHAT_MILESTONE_SMS_ENABLED=false

# Seconds to hold the post-verify PollSubscriptionStatusJob before
# the queue worker runs it. The job polls /subscription/getStatus
# once and finalises the subscription row. Default 10s — long
# enough for the gateway to flip INITIAL CHARGING PENDING →
# REGISTERED, short enough that the user sees the dashboard flip
# without restarting their browser.
BDAPPS_DELAYED_GETSTATUS_SECONDS=10

# Seconds between dashboard auto-refreshes on the "Activating…"
# page. The page meta-refreshes itself until the user is fully
# subscribed. Default 5s.
BDAPPS_PENDING_REFRESH_SECONDS=5

# ─────────────────────────────────────────────────────────────────────
# OpenRouter (OpenAI-compatible chat completions)
# ─────────────────────────────────────────────────────────────────────
# Get an API key at https://openrouter.ai/keys. Required for the
# /api/chat/messages streaming endpoint. Without this, OpenRouterService
# throws on every chat request.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_TIMEOUT=60

# Optional headers for OpenRouter attribution (improves routing
# priority + shows up on their public stats).
OPENROUTER_APP_NAME="Chat App"
OPENROUTER_APP_URL=http://localhost
